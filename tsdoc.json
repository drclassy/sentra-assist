{
  "$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
  "extends": [],
  "noStandardTags": false,
  "tagDefinitions": [
    {
      "tagName": "@alpha",
      "syntaxKind": "modifier"
    },
    {
      "tagName": "@beta",
      "syntaxKind": "modifier"
    },
    {
      "tagName": "@experimental",
      "syntaxKind": "modifier"
    },
    {
      "tagName": "@internal",
      "syntaxKind": "modifier"
    }
  ],
  "supportForTags": {
    "@param": true,
    "@returns": true,
    "@throws": true,
    "@example": true,
    "@remarks": true,
    "@deprecated": true,
    "@see": true,
    "@public": true,
    "@private": true,
    "@protected": true
  }
}
