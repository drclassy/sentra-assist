# Blueprinted & built by Claudesy.
# Sentra Assist Environment Configuration
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# =============================================================================
# SENTRA BACKEND API
# =============================================================================

# API Base URL (HTTPS required in production)
VITE_SENTRA_API_URL=https://api.sentra.local

# API Authentication Key (get from Sentra admin)
VITE_SENTRA_API_KEY=sk_dev_your_api_key_here

# Facility identifier for multi-tenant setup
VITE_FACILITY_ID=PUSKESMAS_BALOWERTI

# =============================================================================
# DEVELOPMENT OPTIONS
# =============================================================================

# Enable mock responses for development (true/false)
# Set to "true" to use local mock data instead of real API
VITE_USE_MOCK=true

# API request timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# Enable debug logging (true/false)
VITE_DEBUG=false

# Enable focused debug logging for visit history scraper/bridge
VITE_DEBUG_RIWAYAT=false

# Enable scoped debug channels (fallback to VITE_DEBUG when omitted)
VITE_DEBUG_BACKGROUND=false
VITE_DEBUG_CONTENT=false
VITE_DEBUG_FILLER=false

# Message timeout tuning (ms) with runtime clamping [1000..60000]
VITE_MESSAGE_TIMEOUT_DEFAULT=10000
VITE_MESSAGE_TIMEOUT_FILL=8000
VITE_MESSAGE_TIMEOUT_SCRAPE=5000
VITE_MESSAGE_TIMEOUT_VISIT_FETCH=15000
VITE_MESSAGE_TIMEOUT_AI=30000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable AI diagnosis suggestions
VITE_FEATURE_DIAGNOSIS_AI=true

# Enable AI prescription recommendations
VITE_FEATURE_PRESCRIPTION_AI=true

# Enable real-time DDI checking
VITE_FEATURE_DDI_CHECK=true

# Enable pediatric dosing calculator
VITE_FEATURE_PEDIATRIC_DOSE=true
