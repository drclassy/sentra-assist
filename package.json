{
  "_brand": "Masterplan and masterpiece by Claudesy.",
  "name": "@the-abyss/sentra-assist",
  "version": "1.0.1",
  "description": "Sentra Assist delivers trustworthy clinical decision support for safer diagnosis workflows and smarter medication guidance in ePuskesmas.",
  "main": "index.js",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:contract": "vitest run lib/api/bridge-client.test.ts",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test tests/e2e --pass-with-no-tests",
    "quality": "npm run typecheck && npm run lint && npm run test",
    "docs:generate": "typedoc",
    "docs:serve": "npx http-server ./docs/api -p 8080 -o",
    "docs:auto": "node scripts/dev/auto-document.js",
    "docs:auto:lib": "node scripts/dev/auto-document.js lib",
    "docs:auto:utils": "node scripts/dev/auto-document.js utils",
    "docs:auto:components": "node scripts/dev/auto-document.js components",
    "docs:all": "node scripts/dev/docs-all.js",
    "commit": "node scripts/dev/auto-commit.js",
    "commit:push": "node scripts/dev/auto-commit.js push",
    "commit:watch": "node scripts/dev/auto-commit.js watch"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@pieces.app/pieces-os-client": "^4.1.0",
    "apexcharts": "^5.3.6",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "react-apexcharts": "^1.9.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.42",
    "@types/node": "22.19.18",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.6",
    "@vitest/ui": "2.1.9",
    "@webext-core/messaging": "1.4.0",
    "@wxt-dev/module-react": "1.2.2",
    "@wxt-dev/storage": "1.2.8",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "jsdom": "25.0.1",
    "playwright": "1.59.1",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.34.5",
    "tailwindcss": "3.4.19",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "6.4.2",
    "vitest": "2.1.9",
    "wxt": "0.20.25"
  },
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "tests"
  },
  "type": "commonjs",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "esbuild@<0.25.0": "0.25.12",
      "markdown-it@<14.1.1": "14.1.1",
      "ajv@>=6.0.0 <6.14.0": "6.14.0",
      "vite": "6.4.2",
      "effect": "3.20.0",
      "@vitejs/plugin-react": "4.3.4"
    }
  }
}
