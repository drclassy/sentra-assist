{
  "_brand": "Masterplan and masterpiece by Claudesy.",
  "name": "@the-abyss/sentra-assist",
  "version": "1.0.1",
  "description": "Sentra Assist delivers trustworthy clinical decision support for safer diagnosis workflows and smarter medication guidance in ePuskesmas.",
  "main": "index.js",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:contract": "vitest run lib/api/bridge-client.test.ts",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test tests/e2e --pass-with-no-tests",
    "quality": "npm run typecheck && npm run lint && npm run test",
    "docs:generate": "typedoc",
    "docs:serve": "npx http-server ./docs/api -p 8080 -o",
    "docs:auto": "node scripts/dev/auto-document.js",
    "docs:auto:lib": "node scripts/dev/auto-document.js lib",
    "docs:auto:utils": "node scripts/dev/auto-document.js utils",
    "docs:auto:components": "node scripts/dev/auto-document.js components",
    "docs:all": "node scripts/dev/docs-all.js",
    "commit": "node scripts/dev/auto-commit.js",
    "commit:push": "node scripts/dev/auto-commit.js push",
    "commit:watch": "node scripts/dev/auto-commit.js watch"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@pieces.app/pieces-os-client": "^4.1.0",
    "apexcharts": "^5.14.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react-apexcharts": "^2.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.43",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/ui": "4.1.8",
    "@webext-core/messaging": "3.0.2",
    "@wxt-dev/module-react": "1.2.2",
    "@wxt-dev/storage": "1.2.8",
    "autoprefixer": "10.5.0",
    "eslint": "10.4.1",
    "eslint-plugin-react": "7.37.5",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.0",
    "tailwindcss": "4.3.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wxt": "0.20.26"
  },
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "tests"
  },
  "type": "commonjs",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "10.2.5",
      "minimatch@>=9.0.0 <9.0.7": "10.2.5",
      "minimatch@>=10.0.0 <10.2.3": "10.2.5",
      "rollup@>=4.0.0 <4.59.0": "4.61.1",
      "esbuild@<0.25.0": "0.28.0",
      "markdown-it@<14.1.1": "14.2.0",
      "ajv@>=6.0.0 <6.14.0": "8.20.0",
      "vite": "8.0.16",
      "effect": "3.21.3",
      "@vitejs/plugin-react": "6.0.2"
    }
  }
}
